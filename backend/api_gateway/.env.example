# ── External API keys ──────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_key_here
AGMARKNET_API_KEY=your_agmarknet_key_here

# ── Exotel IVR ─────────────────────────────────────────────────────────────────
# Full public URL of your tunnel (Ngrok / Localtunnel). No trailing slash.
# Must be updated each time the tunnel is restarted (unless on a paid static plan).
# Example: https://abc123.ngrok.io
TUNNEL_BASE_URL=https://your-tunnel.ngrok.io
