# KisanSetu IVR Configuration
# Copy this to .env and fill in your values

# ==================== Database ====================
DATABASE_URL=postgresql://kisan_admin:kisan_password@localhost:5432/kisansetu

# ==================== Twilio Configuration ====================
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ==================== Weather API (OpenWeather) ====================
# Get free API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key

# ==================== Market Prices API (AGMARKNET - India Gov) ====================
# Get free API key from https://data.gov.in (search for AgMarkNET)
AGMARKNET_API_KEY=your_agmarknet_api_key

# ==================== Africa's Talking (for Africa) ====================
# Get these from https://account.africastalking.com
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_SHORTCODE=your_shortcode

# ==================== Google Cloud (TTS/STT) ====================
# Create a project and enable Cloud Text-to-Speech and Speech API
GOOGLE_CLOUD_PROJECT=your-project-id
# Download your service account JSON and reference it
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# ==================== Disease Detection ====================
DISEASE_MODEL_PATH=/app/assets/models/kisansetu_v38.tflite

# ==================== IVR Settings ====================
IVR_PROVIDER=twilio  # Options: twilio, africastalking
DEFAULT_LANGUAGE=hi
CALL_TIMEOUT=300
MAX_RECORDING_DURATION=30

# ==================== Redis (Session Storage) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==================== API Gateway ====================
API_GATEWAY_URL=http://localhost:8000